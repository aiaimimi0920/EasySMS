{
  "name": "easy-sms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-runtime-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
